    "comparison_faq": {
      "type": "comparison-faq",
      "blocks": {
        "faq_DFeDJn": {
          "type": "faq",
          "settings": {
            "q": "Will this actually help with menopausal hair thinning?",
            "a": "Filtered water doesn't reverse hormonal hair loss — nothing topical can. What it does is remove the external damage (chlorine, heavy metals, mineral buildup) that's compounding what hormones are already doing. Your hair is under stress from declining estrogen. Unfiltered water adds a second layer. Remove that, and your hair can focus on recovering from just one. Most women see improvement in breakage, shedding, and texture within 4–8 weeks."
          }
        },
        "faq_cM8Jj7": {
          "type": "faq",
          "settings": {
            "q": "I already use expensive hair products. Do I need this too?",
            "a": "If your water contains chlorine and hard water minerals, those products aren't working at full capacity. Hard water creates a mineral film that blocks product absorption. Many customers report needing less product after switching — because products actually penetrate. A $30 serum on mineral-coated hair is a $30 serum sitting on the surface."
          }
        },
        "faq_LrnrNt": {
          "type": "faq",
          "settings": {
            "q": "What's the difference between the 2.0 and 5.0?",
            "a": "The 2.0 Handheld has a 5-stage filter (Sediment, Calcium Sulfite, Vitamin C, KDF-55, Catalytic Carbon) that removes chlorine, chloramines, heavy metals, PFAS, and VOCs. It has 3 spray modes and a flexible hose. The 5.0 Stationary has a 15-stage filter that also removes chloramines, fluoride, VOCs, THMs, and infuses Vitamin C and E. It's wall-mounted with a 6-month filter life vs. 3 months. For women with significant hormonal hair changes, sensitive skin, or very hard water, the 5.0 is worth the upgrade."
          }
        },
        "faq_yMzaqr": {
          "type": "faq",
          "settings": {
            "q": "How do I know if my water is bad?",
            "a": "85% of U.S. homes have hard water, and 98% use chlorine-based disinfection. If you live in the U.S., your water almost certainly contains contaminants affecting your hair and skin. Both kits include a test strip so you can see your before and after."
          }
        },
        "faq_N7G7N4": {
          "type": "faq",
          "settings": {
            "q": "I have eczema/psoriasis. Will this help?",
            "a": "Dermatologists frequently recommend shower filters for eczema and psoriasis. Chlorine strips natural oils and kills beneficial bacteria — both worsen inflammatory skin conditions. Many customers report significant reduction in flare-ups. The 5.0's vitamin C infusion and pH rebalancing provide additional soothing for sensitive skin."
          }
        },
        "faq_6pJ7tM": {
          "type": "faq",
          "settings": {
            "q": "How hard is installation?",
            "a": "Under 5 minutes. Both use standard ½-inch connections that fit any U.S. shower arm. Unscrew old head, hand-tighten the new one. The built-in rubber gasket creates a watertight seal. No plumber, no special tools, no YouTube tutorial."
          }
        },
        "faq_8ywj8R": {
          "type": "faq",
          "settings": {
            "q": "What if it doesn't work for me?",
            "a": "The 2.0 has a 60-day guarantee. The 5.0 has a 90-day guarantee (because deeper filtration takes longer to show hair results). No hoops, no restocking fees. Full refund. We set the guarantee at 90 days specifically because hair growth cycles take 8–12 weeks."
          }
        }
      },
