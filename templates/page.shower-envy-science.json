    "science_experts": {
      "type": "shower-science-experts",
      "blocks": {
        "derm_card_N8ptjY": {
          "type": "derm_card",
          "settings": {
            "area": "On Shower Filters",
            "quote": "Dermatologists often recommend shower filters for patients with sensitive skin or chronic conditions like eczema and acne. Removing chlorine and metals helps prevent dryness and irritation while maintaining skin hydration and elasticity.\"",
            "source": "— Dr. Dendy Engelman / AAD research",
            "animation_class": "rv-left rv-d1"
          }
        },
        "derm_card_6AzLC8": {
          "type": "derm_card",
          "settings": {
            "area": "On Menopause & Skin",
            "quote": "\"The perimenopausal years are marked by an accelerated decline in skin quality, largely due to declining estrogen levels. Collagen content declines at 2.1% per postmenopausal year, correlating with estrogen deficiency rather than chronological age.\"",
            "source": "— Brincat et al. / European Medical Journal",
            "animation_class": "rv-right rv-d2"
          }
        },
        "derm_card_7w9jDf": {
          "type": "derm_card",
          "settings": {
            "area": "On Hard Water & Eczema",
            "quote": "\"Hard water leaves behind mineral residue that can clog pores and dry out skin by disrupting its natural barrier. For people with eczema or psoriasis, the barrier is already thinner and more delicate — making filtered water a particularly meaningful intervention.\"",
            "source": "— Vitaclean / dermatology research",
            "animation_class": "rv-left rv-d1"
          }
        },
        "derm_card_BpXVjP": {
          "type": "derm_card",
          "settings": {
            "area": "On Chlorine & Skin",
            "quote": "\"Chlorine is a strong oxidant that causes damage to skin and hair even at very low levels. Most tap water maintains chlorine levels greater than recommended for swimming pools. It kills beneficial bacteria on the skin surface that provides natural defense against skin disorders.\"",
            "source": "— Aquasana dermatological research",
            "animation_class": "rv-right rv-d2"
          }
        }
      },
