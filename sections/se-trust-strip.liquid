{% style %}#shopify-section-{{ section.id }}{background:{{ section.settings.bg }};color:{{ section.settings.text }};padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px}{% endstyle %}
{% if section.settings.custom_html != blank %}
  {{ section.settings.custom_html }}
{% else %}
{% if section.settings.custom_svg != blank %}<div class="se-custom-svg">{{ section.settings.custom_svg }}</div>{% endif %}
<section class="trust-strip__signal-bloom-flare">
  <div class="trust-strip__signal-bloom-glow">
    {% assign badge_index = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'trust_badge' %}
        {% assign badge_index = badge_index | plus: 1 %}
        <div class="trust-strip__signal-bloom-harbor" {{ block.shopify_attributes }}><span class="{% case badge_index %}{% when 1 %}trust-strip__signal-bloom-ivory{% when 2 %}trust-strip__signal-bloom-jade{% when 3 %}trust-strip__signal-bloom-kindle{% when 4 %}trust-strip__signal-bloom-lumen{% else %}trust-strip__signal-bloom-meadow{% endcase %}">{{ block.settings.icon }}</span>{{ block.settings.text }}</div>
      {% endif %}
    {% endfor %}
    {% if badge_index == 0 %}
      <div class="trust-strip__signal-bloom-harbor"><span class="trust-strip__signal-bloom-ivory">🩺</span>Dermatologist Recommended</div>
      <div class="trust-strip__signal-bloom-harbor"><span class="trust-strip__signal-bloom-jade">⏱</span>Installs in 3 Minutes</div>
      <div class="trust-strip__signal-bloom-harbor"><span class="trust-strip__signal-bloom-kindle">✓</span>NSF/ANSI Certified</div>
      <div class="trust-strip__signal-bloom-harbor"><span class="trust-strip__signal-bloom-lumen">📦</span>Free Shipping &amp; Returns</div>
      <div class="trust-strip__signal-bloom-harbor"><span class="trust-strip__signal-bloom-meadow">🇺🇸</span>Made in the USA</div>
    {% endif %}
  </div>
</section>

<div class="reveal-up is-visible hero__panel-bloom-ember">
  <section class="trust-strip__signal-bloom-nova">
    <div class="trust-strip__signal-bloom-oasis">
      {% assign lifestyle_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'lifestyle_card' %}
          {% assign lifestyle_index = lifestyle_index | plus: 1 %}
          <div class="{% case lifestyle_index %}{% when 2 %}trust-strip__signal-bloom-solace{% when 3 %}trust-strip__signal-bloom-velvet{% else %}trust-strip__signal-bloom-pulse{% endcase %}" {{ block.shopify_attributes }}>
            <span class="hero__panel-aurora-oasis">{{ block.settings.icon }}</span>
            <span class="{% case lifestyle_index %}{% when 2 %}trust-strip__signal-bloom-thrive{% when 3 %}trust-strip__signal-bloom-whisper{% else %}trust-strip__signal-bloom-quartz{% endcase %}">{{ block.settings.caption }}</span>
            <span class="{% case lifestyle_index %}{% when 2 %}trust-strip__signal-bloom-uplift{% when 3 %}trust-strip__signal-bloom-xenial{% else %}trust-strip__signal-bloom-ripple{% endcase %}">{% if block.settings.image != blank %}<img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">{% else %}Upload image here{% endif %}</span>
          </div>
        {% endif %}
      {% endfor %}
      {% if lifestyle_index == 0 %}
        <div class="trust-strip__signal-bloom-pulse"><span class="hero__panel-aurora-oasis">🚿</span><span class="trust-strip__signal-bloom-quartz">Lifestyle — Woman 50+ enjoying shower</span><span class="trust-strip__signal-bloom-ripple">Upload image here</span></div>
        <div class="trust-strip__signal-bloom-solace"><span class="hero__panel-aurora-oasis">✨</span><span class="trust-strip__signal-bloom-thrive">Lifestyle — Healthy glowing skin</span><span class="trust-strip__signal-bloom-uplift">Upload image here</span></div>
        <div class="trust-strip__signal-bloom-velvet"><span class="hero__panel-aurora-oasis">💇‍♀️</span><span class="trust-strip__signal-bloom-whisper">Lifestyle — Full healthy hair</span><span class="trust-strip__signal-bloom-xenial">Upload image here</span></div>
        <div class="trust-strip__signal-bloom-pulse"><span class="hero__panel-aurora-oasis">😊</span><span class="trust-strip__signal-bloom-quartz">Lifestyle — Happy woman in bathroom</span><span class="trust-strip__signal-bloom-ripple">Upload image here</span></div>
      {% endif %}
    </div>
  </section>
</div>
{% endif %}
{% schema %}
{
  "name":"SE Trust Strip",
  "settings":[
    {"type":"color","id":"bg","label":"Background color","default":"#ffffff"},
    {"type":"color","id":"text","label":"Text color","default":"#1f1d1a"},
    {"type":"range","id":"padding_top","label":"Padding top","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"image_picker","id":"section_image","label":"Section image (optional)"},
    {"type":"image_picker","id":"section_image_mobile","label":"Section image mobile (optional)"},
    {"type":"liquid","id":"custom_html","label":"Custom section HTML (advanced)"},
    {"type":"liquid","id":"custom_svg","label":"Custom SVG/HTML snippet (advanced)"}
  ],
  "blocks":[
    {"type":"trust_badge","name":"Trust badge","settings":[
      {"type":"text","id":"icon","label":"Icon","default":"🩺"},
      {"type":"text","id":"text","label":"Text","default":"Dermatologist Recommended"}
    ]},
    {"type":"lifestyle_card","name":"Lifestyle card","settings":[
      {"type":"text","id":"icon","label":"Icon","default":"🚿"},
      {"type":"text","id":"caption","label":"Caption","default":"Lifestyle — Woman 50+ enjoying shower"},
      {"type":"image_picker","id":"image","label":"Image"}
    ]}
  ],
  "presets":[{
    "name":"SE Trust Strip",
    "blocks":[
      {"type":"trust_badge","settings":{"icon":"🩺","text":"Dermatologist Recommended"}},
      {"type":"trust_badge","settings":{"icon":"⏱","text":"Installs in 3 Minutes"}},
      {"type":"trust_badge","settings":{"icon":"✓","text":"NSF/ANSI Certified"}},
      {"type":"trust_badge","settings":{"icon":"📦","text":"Free Shipping & Returns"}},
      {"type":"trust_badge","settings":{"icon":"🇺🇸","text":"Made in the USA"}},
      {"type":"lifestyle_card","settings":{"icon":"🚿","caption":"Lifestyle — Woman 50+ enjoying shower"}},
      {"type":"lifestyle_card","settings":{"icon":"✨","caption":"Lifestyle — Healthy glowing skin"}},
      {"type":"lifestyle_card","settings":{"icon":"💇‍♀️","caption":"Lifestyle — Full healthy hair"}},
      {"type":"lifestyle_card","settings":{"icon":"😊","caption":"Lifestyle — Happy woman in bathroom"}}
    ]
  }]
}
{% endschema %}
