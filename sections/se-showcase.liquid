{% style %}#shopify-section-{{ section.id }}{background:{{ section.settings.bg }};color:{{ section.settings.text }};padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px}{% endstyle %}
        <section class="product-showcase__detail-ember-flare">
            <div class="reveal-up hero__panel-bloom-ember is-visible">
                <div class="concern-section__point-bloom-zenith">
                    <div class="product-showcase__detail-ember-glow">💧</div>
                    <div class="section-eyebrow product-showcase__detail-ember-harbor">{{ section.settings.eyebrow }}</div>
                    <h2 class="product-showcase__detail-ember-ivory">{{ section.settings.main_title }}</h2>
                    <p class="product-showcase__detail-ember-jade">{{ section.settings.main_description }}</p>
                </div>
            </div>
            <div class="reveal-up hero__panel-bloom-ember">
                <section class="mc2-wrap">
                    <div class="mc2-legend">
                        <span class="mc2-dot mc2-dot-rose"></span>
                        <span class="mc2-label mc2-label-rose">Unfiltered Water In</span>
                        <span class="mc2-arrow">→</span>
                        <span class="mc2-label mc2-label-sage">Clean Water Out</span>
                        <span class="mc2-dot mc2-dot-sage"></span>
                    </div>
                    <div class="mc2-row">
                        <article class="mc2-step"><div class="mc2-icon mc2-muted"><span>1</span><small>⊘</small></div><h4>Sediment Pre-Filter</h4><p>Rust, debris, particles</p></article>
                        <div class="mc2-connector-svg"><svg viewBox="0 0 44 44" fill="none"><path d="M10 22h24M28 14l8 8-8 8" stroke="var(--mut)"></path><circle class="mc2-flow-dot" cx="22" cy="22" r="3" fill="var(--mut)"></circle></svg></div>
                        <article class="mc2-step"><div class="mc2-icon mc2-rose"><span>2</span><small>Cl</small></div><h4>Calcium Sulfite</h4><p>Chlorine — instantly</p></article>
                        <div class="mc2-connector-svg"><svg viewBox="0 0 44 44" fill="none"><path d="M10 22h24M28 14l8 8-8 8" stroke="var(--rose)"></path><circle class="mc2-flow-dot" cx="22" cy="22" r="3" fill="var(--rose)"></circle></svg></div>
                        <article class="mc2-step"><div class="mc2-icon mc2-gold"><span>3</span><small>C</small></div><h4>Vitamin C Infusion</h4><p>Antioxidant protection</p></article>
                        <div class="mc2-connector-svg"><svg viewBox="0 0 44 44" fill="none"><path d="M10 22h24M28 14l8 8-8 8" stroke="var(--gold)"></path><circle class="mc2-flow-dot" cx="22" cy="22" r="3" fill="var(--gold)"></circle></svg></div>
                        <article class="mc2-step"><div class="mc2-icon mc2-sage"><span>4</span><small>Pb</small></div><h4>KDF-55 Media</h4><p>Lead, mercury, heavy metals</p></article>
                        <div class="mc2-connector-svg"><svg viewBox="0 0 44 44" fill="none"><path d="M10 22h24M28 14l8 8-8 8" stroke="var(--sage)"></path><circle class="mc2-flow-dot" cx="22" cy="22" r="3" fill="var(--sage)"></circle></svg></div>
                        <article class="mc2-step"><div class="mc2-icon mc2-ink"><span>5</span><small>◉</small></div><h4>Activated Carbon</h4><p>VOCs, THMs, byproducts</p></article>
                    </div>
                </section>
            </div>
            <div class="reveal-up hero__panel-bloom-ember is-visible">
                <div class="product-showcase__detail-flare-aurora">
                    <div class="product-showcase__detail-flare-bloom">
                        <svg width="180" height="72" viewBox="0 0 180 72" fill="none">
                            <rect x="0" y="14" width="44" height="22" rx="11" fill="var(--rose)"></rect>
                            <text x="22" y="30" text-anchor="middle" fill="#fff" font-size="13" font-weight="800">A</text>
                            <rect x="60" y="4" width="44" height="22" rx="11" fill="var(--gold)"></rect>
                            <text x="82" y="20" text-anchor="middle" fill="#fff" font-size="13" font-weight="800">C</text>
                            <rect x="124" y="18" width="44" height="22" rx="11" fill="var(--sage)"></rect>
                            <text x="146" y="34" text-anchor="middle" fill="#fff" font-size="13" font-weight="800">E</text>
                        </svg>
                    </div>
                    <h3 class="product-showcase__detail-flare-crest">{{ section.settings.vitamin_title }}</h3>
                    <p class="product-showcase__detail-flare-drift">{{ section.settings.vitamin_description }}</p>
                    <div class="product-showcase__detail-flare-ember">
                        <div class="card product-showcase__detail-flare-flare">
                            <div class="product-showcase__detail-flare-glow">
                                <svg width="52" height="52" viewBox="0 0 56 56" fill="none">
                                    <path d="M28 4l12 16a16 16 0 1 1-24 0z" fill="var(--rose)" opacity=".12" stroke="var(--rose)" stroke-width="2"></path>
                                    <text x="28" y="36" text-anchor="middle" fill="var(--rose)" font-size="16" font-weight="800" font-family="var(--fb)">A</text>
                                </svg>
                                <div class="product-showcase__detail-flare-harbor">Vitamin A</div>
                            </div>
                            <div class="product-showcase__detail-flare-ivory">Supports collagen production — what your skin loses fastest after menopause</div>
                        </div>
                        <div class="card product-showcase__detail-flare-jade">
                            <div class="product-showcase__detail-flare-glow">
                                <svg width="52" height="52" viewBox="0 0 56 56" fill="none">
                                    <path d="M28 4l12 16a16 16 0 1 1-24 0z" fill="var(--gold)" opacity=".12" stroke="var(--gold)" stroke-width="2"></path>
                                    <text x="28" y="36" text-anchor="middle" fill="var(--gold)" font-size="16" font-weight="800" font-family="var(--fb)">C</text>
                                </svg>
                                <div class="product-showcase__detail-flare-kindle">Vitamin C</div>
                            </div>
                            <div class="product-showcase__detail-flare-ivory">Neutralizes chlorine on contact AND delivers the #1 anti-aging ingredient to skin</div>
                        </div>
                        <div class="card product-showcase__detail-flare-lumen">
                            <div class="product-showcase__detail-flare-glow">
                                <svg width="52" height="52" viewBox="0 0 56 56" fill="none">
                                    <path d="M28 4l12 16a16 16 0 1 1-24 0z" fill="var(--sage)" opacity=".12" stroke="var(--sage)" stroke-width="2"></path>
                                    <text x="28" y="36" text-anchor="middle" fill="var(--sage)" font-size="16" font-weight="800" font-family="var(--fb)">E</text>
                                </svg>
                                <div class="product-showcase__detail-flare-meadow">Vitamin E</div>
                            </div>
                            <div class="product-showcase__detail-flare-ivory">Repairs the moisture barrier your skin can no longer maintain on its own</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

{% schema %}
{
  "name":"SE Showcase",
  "settings":[
    {"type":"color","id":"bg","label":"Background color","default":"#ffffff"},
    {"type":"color","id":"text","label":"Text color","default":"#1f1d1a"},
    {"type":"range","id":"padding_top","label":"Padding top","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"OUR APPROACH"},
    {"type":"text","id":"main_title","label":"Main title","default":"Subtraction, Not Addition."},
    {"type":"textarea","id":"main_description","label":"Main description","default":"You don't need another product piled on top. You need to remove what's undoing everything."},
    {"type":"text","id":"vitamin_title","label":"Vitamin section title","default":"The Vitamin Infusion That Sets Us Apart"},
    {"type":"textarea","id":"vitamin_description","label":"Vitamin section description","default":"No other showerhead delivers all three."},
    {"type":"image_picker","id":"section_image","label":"Section image (optional)"},
    {"type":"image_picker","id":"section_image_mobile","label":"Section image mobile (optional)"}
  ],
  "presets":[{"name":"SE Showcase"}]
}
{% endschema %}
