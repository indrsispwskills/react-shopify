{% style %}#shopify-section-{{ section.id }}{background:{{ section.settings.bg }};color:{{ section.settings.text }};padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px}{% endstyle %}
{% if section.settings.custom_html != blank %}
  {{ section.settings.custom_html }}
{% else %}
{% if section.settings.custom_svg != blank %}<div class="se-custom-svg">{{ section.settings.custom_svg }}</div>{% endif %}
        <footer class="site-footer__detail-lumen-meadow">
            <div class="site-footer__detail-lumen-nova">
                <div class="site-footer__detail-lumen-oasis">
                    <div class="site-footer__detail-lumen-pulse">
                        <svg width="24" height="24" viewBox="0 0 32 32" class="hero__panel-ember">
                            <circle cx="16" cy="16" r="14" fill="rgba(94,138,106,.12)"></circle>
                            <path d="M16 8v5M12 16c0-2.2 1.8-4 4-4s4 1.8 4 4M13 19s1 3 3 3 3-3 3-3" stroke="var(--sage)" stroke-width="2" stroke-linecap="round" fill="none"></path>
                            <circle cx="16" cy="24" r="1.2" fill="var(--sage)"></circle>
                        </svg><span>Shower<span class="hero__panel-flare">Envy</span></span>
                    </div>
                    <div class="site-footer__detail-lumen-quartz">Filtered Showerheads for Women Over 50</div>
                    <p class="site-footer__detail-lumen-ripple">Designed for women navigating hormonal changes. Because your water should help — not hurt.</p>
                </div>
                <div class="site-footer__detail-lumen-solace">
                    <div>
                        <div class="site-footer__detail-lumen-thrive">{{ section.settings.footer_menu_1_title }}</div>
                        {% if section.settings.footer_menu_1 != blank %}
                          {% for link in section.settings.footer_menu_1.links %}
                            <a href="{{ link.url }}" class="site-footer__detail-lumen-uplift">{{ link.title }}</a>
                          {% endfor %}
                        {% else %}
                          <div class="site-footer__detail-lumen-uplift">The 2.0 Handheld</div>
                          <div class="site-footer__detail-lumen-uplift">The 5.0 Stationary</div>
                          <div class="site-footer__detail-lumen-uplift">Filters</div>
                          <div class="site-footer__detail-lumen-uplift">Bundles</div>
                        {% endif %}
                    </div>
                    <div>
                        <div class="site-footer__detail-lumen-thrive">{{ section.settings.footer_menu_2_title }}</div>
                        {% if section.settings.footer_menu_2 != blank %}
                          {% for link in section.settings.footer_menu_2.links %}
                            <a href="{{ link.url }}" class="site-footer__detail-lumen-uplift">{{ link.title }}</a>
                          {% endfor %}
                        {% else %}
                          <div class="site-footer__detail-lumen-uplift">How It Works</div>
                          <div class="site-footer__detail-lumen-uplift">Results Timeline</div>
                          <div class="site-footer__detail-lumen-uplift">Blog</div>
                          <div class="site-footer__detail-lumen-uplift">Reviews</div>
                        {% endif %}
                    </div>
                    <div>
                        <div class="site-footer__detail-lumen-thrive">{{ section.settings.footer_menu_3_title }}</div>
                        {% if section.settings.footer_menu_3 != blank %}
                          {% for link in section.settings.footer_menu_3.links %}
                            <a href="{{ link.url }}" class="site-footer__detail-lumen-uplift">{{ link.title }}</a>
                          {% endfor %}
                        {% else %}
                          <div class="site-footer__detail-lumen-uplift">Questions</div>
                          <div class="site-footer__detail-lumen-uplift">Returns</div>
                          <div class="site-footer__detail-lumen-uplift">Guarantee</div>
                          <div class="site-footer__detail-lumen-uplift">Contact</div>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="site-footer__detail-lumen-velvet"><span>© 2026 ShowerEnvy</span><span>Privacy · Terms · Accessibility</span></div>
        </footer>
        <button aria-label="Back to top" class="site-footer__detail-lumen-whisper back-to-top">↑</button>

{% endif %}
{% schema %}
{
  "name":"SE Footer",
  "settings":[
    {"type":"color","id":"bg","label":"Background color","default":"#ffffff"},
    {"type":"color","id":"text","label":"Text color","default":"#1f1d1a"},
    {"type":"range","id":"padding_top","label":"Padding top","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"image_picker","id":"section_image","label":"Section image (optional)"},
    {"type":"image_picker","id":"section_image_mobile","label":"Section image mobile (optional)"},
    {"type":"text","id":"footer_menu_1_title","label":"Footer column 1 title","default":"Shop"},
    {"type":"link_list","id":"footer_menu_1","label":"Footer column 1 menu"},
    {"type":"text","id":"footer_menu_2_title","label":"Footer column 2 title","default":"Learn"},
    {"type":"link_list","id":"footer_menu_2","label":"Footer column 2 menu"},
    {"type":"text","id":"footer_menu_3_title","label":"Footer column 3 title","default":"Support"},
    {"type":"link_list","id":"footer_menu_3","label":"Footer column 3 menu"},
    {"type":"liquid","id":"custom_html","label":"Custom section HTML (advanced)"},
    {"type":"liquid","id":"custom_svg","label":"Custom SVG/HTML snippet (advanced)"}
  ],
  "presets":[{"name":"SE Footer"}]
}
{% endschema %}
