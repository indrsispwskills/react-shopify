{% schema %}
{
  "name":"SE Science",
  "settings":[
    {"type":"color","id":"bg","label":"Background color","default":"#ffffff"},
    {"type":"color","id":"text","label":"Text color","default":"#1f1d1a"},
    {"type":"range","id":"padding_top","label":"Padding top","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"text","id":"section_eyebrow","label":"Eyebrow","default":"THE ROOT CAUSE"},
    {"type":"text","id":"title_line_1","label":"Title line 1","default":"It's Not Your Products."},
    {"type":"text","id":"title_highlight","label":"Title highlight","default":"It's Your Water."},
    {"type":"textarea","id":"title_description","label":"Title description","default":"Two forces are working against your skin and hair — one from inside, one from outside."},
    {"type":"image_picker","id":"section_image","label":"Section image (optional)"},
    {"type":"image_picker","id":"section_image_mobile","label":"Section image mobile (optional)"}
  ],
  "presets":[{"name":"SE Science"}]
}
{% endschema %}
