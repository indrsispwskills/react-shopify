{% schema %}
{
  "name": "SE Hero",
  "settings": [
    {"type":"text","id":"tagline","label":"Tagline","default":"Filtered Showerheads for Women Over 50"},
    {"type":"liquid","id":"headline","label":"Headline (HTML allowed)","default":"You Spend $200/mo<br>on Hair &amp; Skin.<br><span class=\"hero__panel-zenith\">Your Shower Undoes It Every Morning.</span>"},
    {"type":"text","id":"primary_label","label":"Primary button label","default":"Find Your Filter"},
    {"type":"text","id":"secondary_label","label":"Secondary button label","default":"How It Works"},
    {"type":"image_picker","id":"hero_image","label":"Hero image"},
    {"type":"liquid","id":"custom_shower_svg","label":"Custom SVG/HTML (overrides default shower SVG)"}
    ,{"type":"liquid","id":"custom_html","label":"Custom section HTML (advanced)"}
    ,{"type":"liquid","id":"custom_svg","label":"Custom SVG/HTML snippet (advanced)"}
  ],
  "presets":[{"name":"SE Hero"}]
}
{% endschema %}
