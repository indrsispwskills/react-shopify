<div class="wrap">
<section id="hair" class="section-cream rv">
  <div class="content-max">

    <!-- HEADER -->
    <div class="s-head">
      <div class="section-icon section-icon--teal rv-scale">💇‍♀️</div>

      <div class="s-tag" style="color:var(--sage)">
        {{ section.settings.tag }}
      </div>

      <h2 class="s-title">
        {{ section.settings.title }}
      </h2>

      <p class="s-sub">
        {{ section.settings.description }}
      </p>
    </div>


  <div class="illust rv-scale rv-d1">
      <svg width="340" height="120" viewBox="0 0 340 120" fill="none">
        <g><rect x="20" y="40" width="80" height="70" rx="10" fill="#E8F5F3" stroke="#5E8A6A" stroke-width="1"/><ellipse cx="60" cy="40" rx="20" ry="6" fill="#5E8A6A" opacity=".2"/><rect x="56" y="10" width="8" height="40" rx="4" fill="#1B3A4B"/><circle cx="60" cy="80" r="12" fill="#5E8A6A" opacity=".2" stroke="#5E8A6A" stroke-width="1"/><circle cx="60" cy="80" r="5" fill="#5E8A6A"/><text x="60" y="4" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="8" fill="#5E8A6A">↑ Growing</text><text x="60" y="118" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="10" fill="#5E8A6A" font-weight="700">ANAGEN</text></g>
        <g><rect x="130" y="40" width="80" height="70" rx="10" fill="#F5EDE3" stroke="#B08642" stroke-width="1"/><ellipse cx="170" cy="40" rx="16" ry="5" fill="#B08642" opacity=".2"/><rect x="167" y="18" width="6" height="32" rx="3" fill="#8A857D"/><circle cx="170" cy="75" r="9" fill="#B08642" opacity=".2" stroke="#B08642" stroke-width="1"/><circle cx="170" cy="75" r="4" fill="#B08642"/><text x="170" y="12" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="8" fill="#B08642">⏸ Transition</text><text x="170" y="118" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="10" fill="#B08642" font-weight="700">CATAGEN</text></g>
        <g><rect x="240" y="40" width="80" height="70" rx="10" fill="#f3f4f6" stroke="#B5B0A8" stroke-width="1"/><ellipse cx="280" cy="40" rx="12" ry="4" fill="#B5B0A8" opacity=".2"/><rect x="278" y="26" width="4" height="20" rx="2" fill="#B5B0A8"/><circle cx="280" cy="72" r="7" fill="#B5B0A8" opacity=".2" stroke="#B5B0A8" stroke-width="1"/><circle cx="280" cy="72" r="3" fill="#B5B0A8"/><text x="280" y="20" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="8" fill="#B5B0A8">💤 Resting</text><text x="280" y="118" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="10" fill="#B5B0A8" font-weight="700">TELOGEN</text></g>
        <path d="M105,65 L125,65" stroke="#E8E5E0" stroke-width="1.5" marker-end="url(#aGy)"/><path d="M215,65 L235,65" stroke="#E8E5E0" stroke-width="1.5" marker-end="url(#aGy)"/>
        <defs><marker id="aGy" markerWidth="6" markerHeight="6" refX="6" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6" fill="#E8E5E0"/></marker></defs>
      </svg>
    </div>


    <!-- HAIR PHASE CARDS -->
<div class="phase-grid">
      <div class="phase-card rv-left rv-d1" style="border:2px solid rgba(94,138,106,.2)"><div class="phase-top"><span style="font-size:26px">📈</span><span class="phase-tag" style="color:var(--sage)">ANAGEN</span></div><h4>Growth Phase</h4><div class="phase-meta"><span style="color:var(--sage);font-weight:600">2–7 years</span><span style="color:var(--light)">|</span><span style="color:var(--muted)">85–90% of hairs</span></div><p>Active growth. Your follicle produces a hair shaft. Matrix cells divide rapidly. Melanocytes add pigment. This is when healthy, visible hair is being built.</p><div class="phase-bar"><div class="phase-bar-fill" style="--fill:88%;background:linear-gradient(90deg,var(--sage2),var(--sage))"></div></div></div>
      <div class="phase-card rv-scale rv-d2" style="border:2px solid rgba(176,134,66,.2)"><div class="phase-top"><span style="font-size:26px">⏸️</span><span class="phase-tag" style="color:var(--gold)">CATAGEN</span></div><h4>Transition Phase</h4><div class="phase-meta"><span style="color:var(--gold);font-weight:600">2–4 weeks</span><span style="color:var(--light)">|</span><span style="color:var(--muted)">~2% of hairs</span></div><p>Growth stops. The follicle shrinks and detaches from its blood supply. The hair shaft fully keratinizes and becomes a 'club hair' — formed but no longer growing.</p><div class="phase-bar"><div class="phase-bar-fill" style="--fill:5%;background:linear-gradient(90deg,#f5d5a8,var(--gold))"></div></div></div>
      <div class="phase-card rv-right rv-d3" style="border:2px solid rgba(107,114,128,.15)"><div class="phase-top"><span style="font-size:26px">💤</span><span class="phase-tag" style="color:var(--muted)">TELOGEN</span></div><h4>Resting Phase</h4><div class="phase-meta"><span style="color:var(--muted);font-weight:600">~3 months</span><span style="color:var(--light)">|</span><span style="color:var(--muted)">10–15% of hairs</span></div><p>The follicle is dormant. No growth, no cell division. The club hair sits loosely until the next anagen phase pushes it out. This is normal daily shedding.</p><div class="phase-bar"><div class="phase-bar-fill" style="--fill:14%;background:linear-gradient(90deg,#d4d4d4,#B5B0A8)"></div></div></div>
    </div>


    <!-- CONTENT CARDS -->
    <div class="card-grid">

      <div class="content-card content-card--gold rv-left rv-d2">
        <h4>{{ section.settings.menopause_title }}</h4>

        {% for block in section.blocks %}
        {% if block.type == 'menopause_point' %}

        <div class="item-row" {{ block.shopify_attributes }}>
          <svg class="item-icon" width="16" height="16" viewBox="0 0 16 16">
            <circle cx="8" cy="8" r="8" fill="#B08642" opacity=".15"/>
            <path d="M5 8l2 2 4-4" stroke="#B08642" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>

          <div>
            <strong>{{ block.settings.title }}</strong>
            <br>
            <span style="font-size:14px;color:var(--muted)">
              {{ block.settings.description }}
            </span>
          </div>
        </div>

        {% endif %}
        {% endfor %}

      </div>


      <div class="content-card content-card--red rv-right rv-d3">

        <h4>{{ section.settings.water_title }}</h4>

        {% for block in section.blocks %}
        {% if block.type == 'water_point' %}

        <div class="item-row" {{ block.shopify_attributes }}>
          <span class="warn-icon">⚠</span>

          <div>
            <strong>{{ block.settings.title }}</strong>
            <br>
            <span style="font-size:14px;color:var(--muted)">
              {{ block.settings.description }}
            </span>
          </div>
        </div>

        {% endif %}
        {% endfor %}

      </div>

    </div>



    <!-- TIMELINE TITLE -->
    <h4 style="text-align:center;margin:36px 0 8px;font-size:20px" class="rv rv-d1">
      {{ section.settings.timeline_title }}
    </h4>

    <p style="text-align:center;color:var(--muted);font-size:15px;margin-bottom:24px" class="rv rv-d1">
      {{ section.settings.timeline_description }}
    </p>



    <!-- TIMELINE -->
    <div class="timeline rv rv-d2">

      {% for block in section.blocks %}
      {% if block.type == 'timeline' %}

      <div class="timeline-item" {{ block.shopify_attributes }}>
        <div class="timeline-dot"></div>

        <div class="timeline-label">
          {{ block.settings.label }}
        </div>

        <div class="timeline-text">
          <strong>{{ block.settings.title }}</strong>
          {{ block.settings.description }}
        </div>
      </div>

      {% endif %}
      {% endfor %}

    </div>


    <!-- EXPAND SECTION -->

    <div class="expand rv rv-d3">

      <button class="expand-btn" onclick="toggleExpand(this)" aria-expanded="false">
        <span>{{ section.settings.expand_title }}</span>
        <span class="expand-icon">+</span>
      </button>

      <div class="expand-body">
        <div class="expand-body-inner">

          <p>{{ section.settings.expand_text_1 }}</p>
          <p>{{ section.settings.expand_text_2 }}</p>
          <p>{{ section.settings.expand_text_3 }}</p>

          <p class="cite">
            {{ section.settings.expand_source }}
          </p>

        </div>
      </div>

    </div>


  </div>
</section>
</div>



{% schema %}
{
  "name": "Shower science hair cycle",
  "settings": [

    {
      "type": "text",
      "id": "tag",
      "label": "Section Tag",
      "default": "HAIR BIOLOGY"
    },

    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Your Hair Growth Cycle Is Changing"
    },

    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every hair on your head goes through a 3-phase cycle. Menopause alters the timing. Unfiltered water stresses the cycle further."
    },

    {
      "type": "text",
      "id": "menopause_title",
      "label": "Menopause Section Title",
      "default": "What Menopause Does to This Cycle"
    },

    {
      "type": "text",
      "id": "water_title",
      "label": "Water Damage Title",
      "default": "What Unfiltered Water Does to This Already Compromised Cycle"
    },

    {
      "type": "text",
      "id": "timeline_title",
      "label": "Timeline Title",
      "default": "What to Expect: Your Results Timeline"
    },

    {
      "type": "textarea",
      "id": "timeline_description",
      "label": "Timeline Description",
      "default": "Based on hair biology and customer feedback"
    },

    {
      "type": "text",
      "id": "expand_title",
      "label": "Expand Section Title",
      "default": "Deep Dive: The 8–12 Week Timeline Explained"
    },

    {
      "type": "textarea",
      "id": "expand_text_1",
      "label": "Expand Text 1"
    },

    {
      "type": "textarea",
      "id": "expand_text_2",
      "label": "Expand Text 2"
    },

    {
      "type": "textarea",
      "id": "expand_text_3",
      "label": "Expand Text 3"
    },

    {
      "type": "text",
      "id": "expand_source",
      "label": "Source Text"
    }

  ],

  "blocks": [

    {
      "type": "menopause_point",
      "name": "Menopause Point",
      "settings": [
        {"type":"text","id":"title","label":"Title"},
        {"type":"textarea","id":"description","label":"Description"}
      ]
    },

    {
      "type": "water_point",
      "name": "Water Damage Point",
      "settings": [
        {"type":"text","id":"title","label":"Title"},
        {"type":"textarea","id":"description","label":"Description"}
      ]
    },

    {
      "type": "timeline",
      "name": "Timeline Item",
      "settings": [
        {"type":"text","id":"label","label":"Timeline Label"},
        {"type":"text","id":"title","label":"Timeline Title"},
        {"type":"textarea","id":"description","label":"Timeline Description"}
      ]
    }

  ],

  "presets": [
    {
      "name": "Shower science hair cycle"
    }
  ]
}
{% endschema %}