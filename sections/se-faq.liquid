<section id="faq" class="water-science__fact-crest-oasis">
  <div class="water-science__fact-crest-pulse">
    <div class="section-eyebrow water-science__fact-crest-ripple">QUESTIONS WOMEN ASK MOST</div>
    <h2 class="headline-lg water-science__fact-crest-solace">{{ section.settings.heading }}</h2>
    <p class="subtext-lg water-science__fact-crest-thrive">{{ section.settings.subheading }}</p>

    <div class="faq-section__entry-kindle-zenith">
      {% for block in section.blocks %}
        <div class="reveal-up hero__panel-bloom-ember" {{ block.shopify_attributes }}>
          <div class="card faq-section__entry-kindle-oasis">
            <button class="faq-section__entry-kindle-pulse">
              <span>{{ block.settings.question }}</span>
              <span class="faq-section__entry-kindle-quartz">+</span>
            </button>
            <div class="faq-section__entry-kindle-ripple">
              <div class="faq-section__entry-kindle-solace">{{ block.settings.answer }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name":"SE FAQ",
  "settings":[
    {"type":"text","id":"heading","label":"Heading","default":"Common Questions"},
    {"type":"textarea","id":"subheading","label":"Subheading","default":"Everything women over 50 ask before they switch."}
  ],
  "blocks":[
    {"type":"item","name":"FAQ item","settings":[
      {"type":"text","id":"question","label":"Question","default":"When will I see results?"},
      {"type":"textarea","id":"answer","label":"Answer","default":"Most women feel softer water and less tightness from shower one. Skin improvements typically show in 2–3 weeks."}
    ]}
  ],
  "max_blocks":12,
  "presets":[{"name":"SE FAQ","blocks":[{"type":"item"},{"type":"item"},{"type":"item"},{"type":"item"}]}]
}
{% endschema %}
