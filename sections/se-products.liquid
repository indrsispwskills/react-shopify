{% style %}#shopify-section-{{ section.id }}{background:{{ section.settings.bg }};color:{{ section.settings.text }};padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px}{% endstyle %}
{% if section.settings.custom_html != blank %}
  {{ section.settings.custom_html }}
{% else %}
{% if section.settings.custom_svg != blank %}<div class="se-custom-svg">{{ section.settings.custom_svg }}</div>{% endif %}
        <section id="products" class="product-showcase__detail-ember-flare">
            <div class="reveal-up hero__panel-bloom-ember is-visible">
                <div class="concern-section__point-bloom-zenith">
                    <div class="concern-section__point-crest-aurora">🛡️</div>


                    {% if section.settings.protection_eyebrow != blank %}
  <div class="section-eyebrow concern-section__point-crest-bloom">
    {{ section.settings.protection_eyebrow }}
  </div>
{% endif %}

{% if section.settings.protection_heading != blank %}
  <h2 class="install-steps__note-glow-jade">
    {{ section.settings.protection_heading }}
  </h2>
{% endif %}


                </div>
            </div>
            <div class="install-steps__note-glow-kindle">
                {% assign product = all_products[section.settings.product] %}

<div class="reveal-left hero__panel-bloom-ember is-visible">
  <div class="card install-steps__note-glow-lumen">
    <div class="install-steps__note-glow-meadow">
      <div class="install-steps__note-glow-nova">
        <span class="hero__panel-aurora-oasis">🚿</span>
        <span class="trust-strip__signal-bloom-quartz">
          {{ product.title }}
        </span>
        <span class="trust-strip__signal-bloom-ripple">
          Upload image here
        </span>
      </div>
      <div class="install-steps__note-glow-oasis">
        💧 3 Spray Modes · Handheld
      </div>
    </div>

    <div class="install-steps__note-glow-pulse">

      <span class="install-steps__note-glow-quartz">
        GREAT STARTER
      </span>

      <!-- ✅ Dynamic Title -->
      <h3 class="install-steps__note-glow-ripple">
        {{ product.title }}
      </h3>

      <p class="install-steps__note-glow-solace">
        Removes chlorine, sediment, and heavy metals. The quickest way to stop daily damage.
      </p>

      <!-- ✅ Dynamic Price -->
      <div class="install-steps__note-glow-thrive">
        <span class="install-steps__note-glow-uplift">
          {{ product.price | money }}
        </span>

        {% if product.compare_at_price > product.price %}
          <span class="install-steps__note-glow-velvet">
            {{ product.compare_at_price | money }}
          </span>
        {% endif %}
      </div>

      <!-- SVGs untouched -->
      <div class="install-steps__note-glow-whisper">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="install-steps__note-glow-xenial">
          <circle cx="11" cy="11" r="11" fill="var(--sage)" opacity=".14"></circle>
          <path d="M7 11l3 3L16 9" stroke="var(--sage)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        {{ section.settings.feature_1 }}
      </div>

      <div class="install-steps__note-glow-whisper">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="install-steps__note-glow-xenial">
          <circle cx="11" cy="11" r="11" fill="var(--sage)" opacity=".14"></circle>
          <path d="M7 11l3 3L16 9" stroke="var(--sage)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
         {{ section.settings.feature_2 }}
      </div>

      <div class="install-steps__note-glow-whisper">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="install-steps__note-glow-xenial">
          <circle cx="11" cy="11" r="11" fill="var(--sage)" opacity=".14"></circle>
          <path d="M7 11l3 3L16 9" stroke="var(--sage)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
          {{ section.settings.feature_3 }}
      </div>

      <div class="install-steps__note-glow-whisper">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="install-steps__note-glow-xenial">
          <circle cx="11" cy="11" r="11" fill="var(--sage)" opacity=".14"></circle>
          <path d="M7 11l3 3L16 9" stroke="var(--sage)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
         {{ section.settings.feature_4 }}
      </div>

      <div class="install-steps__note-glow-whisper">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="install-steps__note-glow-xenial">
          <circle cx="11" cy="11" r="11" fill="var(--sage)" opacity=".14"></circle>
          <path d="M7 11l3 3L16 9" stroke="var(--sage)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
         {{ section.settings.feature_5 }}
      </div>

      <!-- ✅ Dynamic Button -->
      <a href="{{ product.url }}" class="btn btn-sage install-steps__note-glow-yonder">
        Shop {{ product.title }} — {{ product.price | money }}
      </a>

    </div>
  </div>
</div>
                {% assign product_advanced = all_products[section.settings.product_advanced] %}

