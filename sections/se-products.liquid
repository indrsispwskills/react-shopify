          <circle cx="11" cy="11" r="11" fill="var(--gold)" opacity=".14"></circle>
          <path d="M7 11l3 3L16 9" stroke="var(--gold)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
