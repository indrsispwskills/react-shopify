{% schema %}
{
  "name":"SE Products",
  "settings":[
    {"type":"color","id":"bg","label":"Background color","default":"#ffffff"},
    {"type":"color","id":"text","label":"Text color","default":"#1f1d1a"},
    {"type":"range","id":"padding_top","label":"Padding top","min":0,"max":120,"step":4,"unit":"px","default":0},
    {"type":"range","id":"padding_bottom","label":"Padding bottom","min":0,"max":120,"step":4,"unit":"px","default":0},
    {
  "type": "text",
  "id": "protection_eyebrow",
  "label": "Protection Eyebrow Text",
  "default": "CHOOSE YOUR PROTECTION"
},
{
  "type": "text",
  "id": "protection_heading",
  "label": "Protection Main Heading",
  "default": "Two Ways to Protect What Your Body Is Already Losing"
},
    {
  "type": "product",
  "id": "product",
  "label": "Select Product"
},

{
  "type": "text",
  "id": "feature_1",
  "label": "Feature 1",
  "default": "Chlorine + sediment + heavy metals"
},
{
  "type": "text",
  "id": "feature_2",
  "label": "Feature 2",
  "default": "3 spray modes"
},
{
  "type": "text",
  "id": "feature_3",
  "label": "Feature 3",
  "default": "Filter life: 3 months"
},
{
  "type": "text",
  "id": "feature_4",
  "label": "Feature 4",
  "default": "60-day money-back guarantee"
},
{
  "type": "text",
  "id": "feature_5",
  "label": "Feature 5",
  "default": "Free shipping"
},
{
  "type": "product",
  "id": "product_advanced",
  "label": "Select Advanced Product (5.0)"
},
{
  "type": "text",
  "id": "feature_6",
  "label": "Feature 6",
  "default": "Full 15-stage + Vitamin A, C & E"
},
{
  "type": "text",
  "id": "feature_7",
  "label": "Feature 7",
  "default": "Chloramines, fluoride, VOCs removed"
},
{
  "type": "text",
  "id": "feature_8",
  "label": "Feature 8",
  "default": "NSF/ANSI Certified · Wall mount"
},
{
  "type": "text",
  "id": "feature_9",
  "label": "Feature 9",
  "default": "Filter life: 6 months"
},
{
  "type": "text",
  "id": "feature_10",
  "label": "Feature 10",
  "default": "90-day money-back guarantee"
},
  ],
  "presets":[{"name":"SE Products"}]
}
{% endschema %}